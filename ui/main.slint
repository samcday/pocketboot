import "fonts/FreeSans.ttf";

export enum BatteryStatus { Unknown, Charging, Discharging, NotCharging, Full }
export enum PowerAction { Shutdown, Reboot }

export struct BootMenuEntry {
    title: string,
    subtitle: string,
    detail: string,
    badge: string,
}

export component MainWindow inherits Window {
    background: #080b12;
    default-font-family: "FreeSans";

    in-out property <string> device-name: "Pocketboot Device";
    in-out property <string> device-detail: "LinuxBoot environment";
    in-out property <string> serialno: "0001";
    in-out property <[BootMenuEntry]> boot-entries: [];
    in-out property <int> boot-entry-count: 0;
    in-out property <bool> boot-scan-complete: false;
    in-out property <int> booting-index: -1;
    in-out property <int> hardware-selected-index: -1;
    in-out property <bool> battery-known: false;
    in-out property <int> battery-percent: 0;
    in-out property <BatteryStatus> battery-status: BatteryStatus.Unknown;
    in-out property <bool> power-menu-open: false;
    in-out property <int> power-menu-selection: 0;
    in-out property <int> hold-action: 0;
    in-out property <int> damage-test-pattern: 0;
    property <duration> hold-start-tick: 0ms;
    out property <float> hold-progress: root.hold-action == 0
        ? 0
        : Math.min(1, 1 * (animation-tick() - root.hold-start-tick) / 2s);

    callback power-action(PowerAction);
    callback boot-entry-selected(int);

    public function show-power-menu() {
        root.power-menu-open = true;
        root.power-menu-selection = 0;
        root.hold-action = 0;
    }

    function hide-power-menu() {
        if (root.hold-action == 0) {
            root.power-menu-open = false;
            root.power-menu-selection = 0;
        }
    }

    function begin-power-hold(action: int) {
        root.hold-start-tick = animation-tick();
        root.hold-action = action;
    }

    function cancel-power-hold(action: int) {
        if (root.hold-action == action) {
            root.hold-action = 0;
        }
    }

    function confirm-power-hold() {
        if (root.hold-action == 1) {
            root.power-action(PowerAction.Shutdown);
        }
        if (root.hold-action == 2) {
            root.power-action(PowerAction.Reboot);
        }
        root.power-menu-open = false;
        root.hold-action = 0;
    }

    function clamp-boot-selection() {
        if (root.boot-entry-count <= 0 || root.booting-index >= 0) {
            root.hardware-selected-index = -1;
            return;
        }

        if (root.hardware-selected-index < 0) {
            root.hardware-selected-index = 0;
        }
        if (root.hardware-selected-index >= root.boot-entry-count) {
            root.hardware-selected-index = root.boot-entry-count - 1;
        }
        root.scroll-boot-selection-into-view();
    }

    function scroll-boot-selection-into-view() {
        if (root.hardware-selected-index < 0 || root.boot-entry-count <= 0) {
            return;
        }

        let row-y = root.hardware-selected-index * 126px;
        let row-height = 112px;
        let visible-y = boot_list.viewport-y + row-y;
        if (visible-y < 0px) {
            boot_list.viewport-y += 0px - visible-y;
        }
        if (visible-y + row-height > boot_list.height) {
            boot_list.viewport-y -= visible-y + row-height - boot_list.height;
        }
    }

    public function refresh-boot-selection() {
        root.clamp-boot-selection();
    }

    function activate-boot-selection() {
        if (root.booting-index >= 0 || root.boot-entry-count <= 0) {
            return;
        }

        root.clamp-boot-selection();
        if (root.hardware-selected-index >= 0) {
            root.booting-index = root.hardware-selected-index;
            root.boot-entry-selected(root.hardware-selected-index);
        }
    }

    function set-power-menu-selection(selection: int) {
        root.hold-action = 0;
        root.power-menu-selection = Math.max(0, Math.min(selection, 2));
    }

    public function hardware-nav-previous() {
        if (root.power-menu-open) {
            root.set-power-menu-selection(root.power-menu-selection - 1);
            return;
        }
        if (root.booting-index >= 0 || root.boot-entry-count <= 0) {
            return;
        }

        root.clamp-boot-selection();
        if (root.hardware-selected-index > 0) {
            root.hardware-selected-index -= 1;
        }
        root.scroll-boot-selection-into-view();
    }

    public function hardware-nav-next() {
        if (root.power-menu-open) {
            root.set-power-menu-selection(root.power-menu-selection + 1);
            return;
        }
        if (root.booting-index >= 0 || root.boot-entry-count <= 0) {
            return;
        }

        root.clamp-boot-selection();
        if (root.hardware-selected-index < root.boot-entry-count - 1) {
            root.hardware-selected-index += 1;
        }
        root.scroll-boot-selection-into-view();
    }

    public function hardware-power-pressed() {
        if (!root.power-menu-open) {
            return;
        }

        if (root.power-menu-selection == 0) {
            root.hide-power-menu();
            return;
        }

        root.begin-power-hold(root.power-menu-selection);
    }

    public function hardware-power-released() {
        if (root.power-menu-open && root.hold-action != 0) {
            root.hold-action = 0;
        }
    }

    public function hardware-power-short-press() {
        if (!root.power-menu-open) {
            root.activate-boot-selection();
        }
    }

    changed boot-entry-count => {
        root.clamp-boot-selection();
    }

    changed hardware-selected-index => {
        root.scroll-boot-selection-into-view();
    }

    Timer {
        interval: 2s;
        running: root.hold-action != 0;
        triggered => {
            root.confirm-power-hold();
        }
    }

    power-button := Rectangle {
        width: 96px;
        height: 76px;
        x: 28px;
        y: 32px;
        background: power-touch.pressed ? #1e293b : #00000000;
        border-radius: 18px;

        ring := Rectangle {
            width: 44px;
            height: 44px;
            x: (parent.width - self.width) / 2;
            y: 20px;
            background: #00000000;
            border-color: #f8fafc;
            border-width: 4px;
            border-radius: 22px;
        }

        Rectangle {
            width: 8px;
            height: 28px;
            x: (parent.width - self.width) / 2;
            y: 11px;
            background: #080b12;
        }

        Rectangle {
            width: 6px;
            height: 30px;
            x: (parent.width - self.width) / 2;
            y: 10px;
            background: #f8fafc;
            border-radius: 3px;
        }

        power-touch := TouchArea {
            width: parent.width;
            height: parent.height;

            clicked => {
                root.show-power-menu();
            }
        }
    }

    battery := Rectangle {
        visible: root.battery-known;
        width: 250px;
        height: 76px;
        x: parent.width - self.width - 32px;
        y: 32px;
        background: #00000000;

        Text {
            width: 128px;
            height: parent.height;
            text: root.battery-percent + "%";
            color: #f8fafc;
            font-size: 42px;
            font-weight: 400;
            horizontal-alignment: right;
            vertical-alignment: center;
        }

        icon := Rectangle {
            width: 84px;
            height: 38px;
            x: 146px;
            y: (parent.height - self.height) / 2;
            background: #00000000;
            border-color: #f8fafc;
            border-width: 4px;
            border-radius: 7px;

            Rectangle {
                x: 5px;
                y: 5px;
                width: (parent.width - 10px) * root.battery-percent / 100;
                height: parent.height - 10px;
                background: (root.battery-status == BatteryStatus.Charging || root.battery-status == BatteryStatus.Full) ? #22c55e : #f8fafc;
                border-radius: 3px;
            }
        }

        Rectangle {
            width: 8px;
            height: 18px;
            x: icon.x + icon.width + 2px;
            y: icon.y + (icon.height - self.height) / 2;
            background: #f8fafc;
            border-radius: 2px;
        }

        Text {
            visible: root.battery-status == BatteryStatus.Charging;
            width: icon.width;
            height: icon.height;
            x: icon.x;
            y: icon.y - 1px;
            text: "+";
            color: #080b12;
            font-size: 32px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    welcome := Rectangle {
        width: parent.width - 64px;
        height: 176px;
        x: 32px;
        y: 132px;
        background: #0f172a;
        border-color: #1e3a5f;
        border-width: 2px;
        border-radius: 28px;

        Text {
            width: parent.width - 48px;
            height: 34px;
            x: 24px;
            y: 22px;
            text: "Welcome to";
            color: #7dd3fc;
            font-size: 24px;
            font-weight: 700;
            horizontal-alignment: left;
            vertical-alignment: center;
        }

        Text {
            width: parent.width - 48px;
            height: 62px;
            x: 24px;
            y: 54px;
            text: root.device-name;
            color: #f8fafc;
            font-size: root.width > 720px ? 44px : 34px;
            font-weight: 700;
            horizontal-alignment: left;
            vertical-alignment: center;
        }

        Text {
            width: parent.width - 48px;
            height: 30px;
            x: 24px;
            y: 116px;
            text: root.device-detail;
            color: #cbd5e1;
            font-size: 20px;
            horizontal-alignment: left;
            vertical-alignment: center;
        }

        Text {
            width: parent.width - 48px;
            height: 26px;
            x: 24px;
            y: 142px;
            text: "serial " + root.serialno;
            color: #94a3b8;
            font-size: 18px;
            horizontal-alignment: left;
            vertical-alignment: center;
        }
    }

    boot_card := Rectangle {
        width: parent.width - 64px;
        height: parent.height - self.y - 40px;
        x: 32px;
        y: 332px;
        background: #0b1220;
        border-color: #1f2937;
        border-width: 2px;
        border-radius: 28px;

        Text {
            width: parent.width - 48px;
            height: 46px;
            x: 24px;
            y: 24px;
            text: root.booting-index >= 0 ? "Booting selected entry" : "Boot Menu";
            color: #f8fafc;
            font-size: 34px;
            font-weight: 700;
            horizontal-alignment: left;
            vertical-alignment: center;
        }

        Text {
            width: parent.width - 48px;
            height: 32px;
            x: 24px;
            y: 68px;
            text: root.booting-index >= 0 ? "Loading kernel and preparing kexec" : root.boot-scan-complete ? "Tap an entry or use volume + power" : "Scanning continues in the background";
            color: #94a3b8;
            font-size: 22px;
            horizontal-alignment: left;
            vertical-alignment: center;
        }

        Text {
            visible: !root.boot-scan-complete && root.boot-entry-count == 0;
            width: parent.width - 48px;
            height: 80px;
            x: 24px;
            y: 138px;
            text: "Scanning local boot media...";
            color: #cbd5e1;
            font-size: 26px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        Text {
            visible: root.boot-scan-complete && root.boot-entry-count == 0;
            width: parent.width - 48px;
            height: 112px;
            x: 24px;
            y: 128px;
            text: "No directly bootable entries found";
            color: #cbd5e1;
            font-size: 26px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        boot_list := Flickable {
            visible: root.boot-entry-count > 0;
            width: parent.width - 48px;
            height: parent.height - self.y - 24px;
            x: 24px;
            y: 116px;
            viewport-width: self.width;
            viewport-height: root.boot-entry-count * 126px;

            for entry[index] in root.boot-entries : Rectangle {
                width: boot_list.width;
                height: 112px;
                y: index * 126px;
                background: root.booting-index == index ? #123047 : row_touch.pressed ? #1e293b : root.hardware-selected-index == index ? #172033 : #111827;
                border-color: root.booting-index == index ? #38bdf8 : root.hardware-selected-index == index ? #7dd3fc : #334155;
                border-width: 2px;
                border-radius: 22px;

                Text {
                    width: parent.width - 190px;
                    height: 36px;
                    x: 22px;
                    y: 15px;
                    text: entry.title;
                    color: #f8fafc;
                    font-size: 26px;
                    font-weight: 700;
                    horizontal-alignment: left;
                    vertical-alignment: center;
                }

                badge := Rectangle {
                    width: 144px;
                    height: 34px;
                    x: parent.width - self.width - 20px;
                    y: 16px;
                    background: root.booting-index == index ? #075985 : root.hardware-selected-index == index ? #164e63 : #1e3a5f;
                    border-radius: 17px;

                    Text {
                        width: parent.width - 16px;
                        height: parent.height;
                        x: 8px;
                        text: entry.badge;
                        color: #e0f2fe;
                        font-size: 16px;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                Text {
                    width: parent.width - 44px;
                    height: 28px;
                    x: 22px;
                    y: 52px;
                    text: entry.subtitle;
                    color: #cbd5e1;
                    font-size: 20px;
                    horizontal-alignment: left;
                    vertical-alignment: center;
                }

                Text {
                    width: parent.width - 44px;
                    height: 24px;
                    x: 22px;
                    y: 80px;
                    text: entry.detail;
                    color: #94a3b8;
                    font-size: 17px;
                    horizontal-alignment: left;
                    vertical-alignment: center;
                }

                row_touch := TouchArea {
                    width: parent.width;
                    height: parent.height;

                    clicked => {
                        if (root.booting-index < 0) {
                            root.booting-index = index;
                            root.boot-entry-selected(index);
                        }
                    }
                }
            }
        }
    }

    Rectangle {
        visible: root.power-menu-open;
        width: parent.width;
        height: parent.height;
        background: #000000aa;

        TouchArea {
            width: parent.width;
            height: parent.height;

            clicked => {
                root.hide-power-menu();
            }
        }

        card := Rectangle {
            width: root.width > 624px ? 560px : root.width - 64px;
            height: 526px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: #111827;
            border-color: #334155;
            border-width: 2px;
            border-radius: 28px;

            Text {
                width: parent.width - 64px;
                height: 56px;
                x: 32px;
                y: 34px;
                text: "Power";
                color: #f8fafc;
                font-size: 42px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            Text {
                width: parent.width - 72px;
                height: 48px;
                x: 36px;
                y: 92px;
                text: "Hold an action; Vol keys navigate";
                color: #94a3b8;
                font-size: 26px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            cancel := Rectangle {
                width: parent.width - 72px;
                height: 54px;
                x: 36px;
                y: 156px;
                background: root.power-menu-selection == 0 ? #334155 : #1f2937;
                border-color: root.power-menu-selection == 0 ? #e2e8f0 : #475569;
                border-width: 2px;
                border-radius: 18px;

                Text {
                    width: parent.width;
                    height: parent.height;
                    text: "Cancel";
                    color: #f8fafc;
                    font-size: 26px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                cancel-touch := TouchArea {
                    width: parent.width;
                    height: parent.height;

                    clicked => {
                        root.hide-power-menu();
                    }
                }
            }

            shutdown := Rectangle {
                width: parent.width - 72px;
                height: 116px;
                x: 36px;
                y: 234px;
                background: root.hold-action == 1 ? #3f1f24 : root.power-menu-selection == 1 ? #332b36 : #1f2937;
                border-color: root.hold-action == 1 || root.power-menu-selection == 1 ? #f97373 : #475569;
                border-width: 2px;
                border-radius: 22px;

                Rectangle {
                    width: root.hold-action == 1 ? parent.width * root.hold-progress : 0px;
                    height: parent.height;
                    background: #dc262655;
                    border-radius: parent.border-radius;
                }

                Text {
                    width: parent.width;
                    height: 50px;
                    y: 19px;
                    text: "Shutdown";
                    color: #f8fafc;
                    font-size: 34px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                Text {
                    width: parent.width;
                    height: 34px;
                    y: 66px;
                    text: root.hold-action == 1 ? "Keep holding..." : "Hold for 2 seconds";
                    color: #cbd5e1;
                    font-size: 22px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                shutdown-touch := TouchArea {
                    width: parent.width;
                    height: parent.height;

                    changed pressed => {
                        if (self.pressed) {
                            root.begin-power-hold(1);
                        } else {
                            root.cancel-power-hold(1);
                        }
                    }
                }
            }

            reboot := Rectangle {
                width: parent.width - 72px;
                height: 116px;
                x: 36px;
                y: 374px;
                background: root.hold-action == 2 ? #142c44 : root.power-menu-selection == 2 ? #17324a : #1f2937;
                border-color: root.hold-action == 2 || root.power-menu-selection == 2 ? #38bdf8 : #475569;
                border-width: 2px;
                border-radius: 22px;

                Rectangle {
                    width: root.hold-action == 2 ? parent.width * root.hold-progress : 0px;
                    height: parent.height;
                    background: #0284c755;
                    border-radius: parent.border-radius;
                }

                Text {
                    width: parent.width;
                    height: 50px;
                    y: 19px;
                    text: "Reboot";
                    color: #f8fafc;
                    font-size: 34px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                Text {
                    width: parent.width;
                    height: 34px;
                    y: 66px;
                    text: root.hold-action == 2 ? "Keep holding..." : "Hold for 2 seconds";
                    color: #cbd5e1;
                    font-size: 22px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                reboot-touch := TouchArea {
                    width: parent.width;
                    height: parent.height;

                    changed pressed => {
                        if (self.pressed) {
                            root.begin-power-hold(2);
                        } else {
                            root.cancel-power-hold(2);
                        }
                    }
                }
            }
        }
    }

    Text {
        visible: false;
        text: "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789%+-:/.()_ Welcome to serial Boot Menu Booting selected entry Loading kernel and preparing kexec Tap a bootable entry to start it use volume power Scanning local boot media No directly bootable entries found Power Cancel Shutdown Reboot Press and hold action seconds Keep holding navigate";
    }

    damage-test-overlay := Rectangle {
        visible: root.damage-test-pattern > 0;
        width: parent.width;
        height: parent.height;
        background: #000000;

        damage-test-tile := Rectangle {
            width: 160px;
            height: 160px;
            x: root.damage-test-pattern == 1 ? 40px
                : root.damage-test-pattern == 2 ? parent.width - self.width - 40px
                : root.damage-test-pattern == 3 ? (parent.width - self.width) / 2
                : root.damage-test-pattern == 4 ? 80px
                : parent.width - self.width - 80px;
            y: root.damage-test-pattern == 1 ? 48px
                : root.damage-test-pattern == 2 ? 48px
                : root.damage-test-pattern == 3 ? (parent.height - self.height) / 2
                : root.damage-test-pattern == 4 ? parent.height - self.height - 64px
                : parent.height - self.height - 64px;
            background: root.damage-test-pattern == 1 ? #ff1744
                : root.damage-test-pattern == 2 ? #00e5ff
                : root.damage-test-pattern == 3 ? #ffea00
                : root.damage-test-pattern == 4 ? #76ff03
                : #d500f9;
        }
    }
}
