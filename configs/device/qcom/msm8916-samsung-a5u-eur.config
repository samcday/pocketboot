# Samsung Galaxy A5U (EUR) LinuxBoot device enablement fragment
# This intentionally covers local board peripherals useful in a
# bootloader-style environment, not display/audio/camera/modem/Wi-Fi.

# Buttons, touchscreen and touchkeys
CONFIG_INPUT=y
CONFIG_INPUT_EVDEV=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_INPUT_MISC=y
CONFIG_INPUT_TOUCHSCREEN=y
CONFIG_KEYBOARD_GPIO=y
CONFIG_INPUT_PM8941_PWRKEY=y
CONFIG_TOUCHSCREEN_MMS114=y
CONFIG_KEYBOARD_TM2_TOUCHKEY=y

# Touchkey LEDs and board GPIO-controlled rails
CONFIG_NEW_LEDS=y
CONFIG_LEDS_CLASS=y
CONFIG_REGULATOR_FIXED_VOLTAGE=y

# Bitbanged I2C sideband buses and USB MUIC
CONFIG_I2C_GPIO=y
CONFIG_EXTCON=y
CONFIG_EXTCON_SM5502=y

# RT5033 PMIC, charger, fuel gauge and board regulators
CONFIG_MFD_RT5033=y
CONFIG_REGULATOR_RT5033=y
CONFIG_CHARGER_RT5033=y
CONFIG_BATTERY_RT5033=y

# Vibrator on the GCC GP2 clock PWM
CONFIG_PWM=y
CONFIG_PWM_CLK=y
CONFIG_INPUT_PWM_VIBRA=y
