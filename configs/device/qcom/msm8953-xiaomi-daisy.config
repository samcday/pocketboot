# Xiaomi Mi A2 Lite (daisy) LinuxBoot device enablement fragment
# This intentionally covers local board peripherals useful in a
# bootloader-style environment, not display/audio/camera/modem/Wi-Fi.

# Buttons and touchscreen
CONFIG_INPUT=y
CONFIG_INPUT_EVDEV=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_INPUT_MISC=y
CONFIG_INPUT_TOUCHSCREEN=y
CONFIG_KEYBOARD_GPIO=y
CONFIG_INPUT_PM8941_PWRKEY=y
CONFIG_TOUCHSCREEN_EDT_FT5X06=y

# Bitbanged sensor bus and LSM6DSL IMU
CONFIG_I2C_GPIO=y
CONFIG_IIO=y
CONFIG_IIO_ST_LSM6DSX=y
CONFIG_IIO_ST_LSM6DSX_I2C=y

# Board GPIO-controlled rails and PMIC WLED backlight
CONFIG_REGULATOR_FIXED_VOLTAGE=y
CONFIG_BACKLIGHT_CLASS_DEVICE=y
CONFIG_BACKLIGHT_QCOM_WLED=y

# Battery, charger and USB connector state
CONFIG_POWER_SUPPLY=y
CONFIG_EXTCON=y
CONFIG_BATTERY_PMI8994_FG=y
CONFIG_CHARGER_QCOM_SMBCHG=y
