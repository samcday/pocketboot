# Samsung Galaxy Tab A 9.7 (2015) LinuxBoot device enablement fragment
# This intentionally covers local board peripherals useful in a
# bootloader-style environment, not display/audio/camera/modem/Wi-Fi.

# Buttons, Hall sensor and touchscreen
CONFIG_INPUT=y
CONFIG_INPUT_EVDEV=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_INPUT_MISC=y
CONFIG_INPUT_TOUCHSCREEN=y
CONFIG_KEYBOARD_GPIO=y
CONFIG_INPUT_PM8941_PWRKEY=y
CONFIG_TOUCHSCREEN_ATMEL_MXT=y

# Board GPIO-controlled rails
CONFIG_REGULATOR_FIXED_VOLTAGE=y

# PM8916 USB cable detection
CONFIG_EXTCON=y
CONFIG_EXTCON_QCOM_SPMI_MISC=y

# MAX77849-compatible fuel gauge
CONFIG_BATTERY_MAX17042=y

# Vibrator on the GCC GP2 clock PWM
CONFIG_PWM=y
CONFIG_PWM_CLK=y
CONFIG_INPUT_PWM_VIBRA=y
