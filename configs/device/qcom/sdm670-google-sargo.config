# Google Pixel 3a (sargo) LinuxBoot device enablement fragment
# This intentionally covers only local board peripherals useful in a
# bootloader-style environment.

# Buttons and touchscreen input
CONFIG_INPUT=y
CONFIG_INPUT_EVDEV=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_INPUT_MISC=y
CONFIG_KEYBOARD_GPIO=y
CONFIG_RMI4_CORE=y
CONFIG_RMI4_I2C=y
CONFIG_RMI4_F12=y

# Haptics
CONFIG_INPUT_DRV2624_HAPTICS=y
