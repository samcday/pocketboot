# DragonBoard 410c LinuxBoot device enablement fragment
# This intentionally covers local board glue, not display/audio/camera/modem/Wi-Fi.

# Buttons
CONFIG_INPUT=y
CONFIG_INPUT_EVDEV=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_KEYBOARD_GPIO=y

# User LEDs
CONFIG_NEW_LEDS=y
CONFIG_LEDS_CLASS=y
CONFIG_LEDS_GPIO=y
CONFIG_LEDS_TRIGGERS=y
CONFIG_LEDS_TRIGGER_HEARTBEAT=y

# USB ID GPIO and onboard USB3503 hub
CONFIG_EXTCON_USB_GPIO=y
CONFIG_USB_HSIC_USB3503=y
