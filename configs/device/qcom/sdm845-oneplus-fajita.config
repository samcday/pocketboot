# OnePlus 6T (fajita) LinuxBoot device enablement fragment
# This intentionally covers local board peripherals useful in a
# bootloader-style environment, not display/audio/camera/modem/Wi-Fi.

# Buttons, alert slider, hall sensor and touchscreen
CONFIG_INPUT=y
CONFIG_INPUT_EVDEV=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_INPUT_MISC=y
CONFIG_INPUT_TOUCHSCREEN=y
CONFIG_KEYBOARD_GPIO=y
CONFIG_INPUT_PM8941_PWRKEY=y
CONFIG_RMI4_CORE=y
CONFIG_RMI4_I2C=y
CONFIG_RMI4_F12=y

# Board GPIO-controlled rails
CONFIG_REGULATOR_FIXED_VOLTAGE=y

# Battery, fuel gauge and PMI8998 charger
CONFIG_POWER_SUPPLY=y
CONFIG_BATTERY_BQ27XXX=y
CONFIG_BATTERY_BQ27XXX_I2C=y
CONFIG_IIO=y
CONFIG_QCOM_SPMI_RRADC=y
CONFIG_QCOM_SPMI_ADC5=y
CONFIG_CHARGER_QCOM_SMB2=y
