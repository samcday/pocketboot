# Samsung Galaxy J7 (2016) LinuxBoot device enablement fragment
# This intentionally covers local board peripherals useful in a
# bootloader-style environment, not display/audio/camera/modem/Wi-Fi.

# Buttons, touchscreen and vibrator
CONFIG_INPUT=y
CONFIG_INPUT_EVDEV=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_INPUT_MISC=y
CONFIG_INPUT_TOUCHSCREEN=y
CONFIG_KEYBOARD_GPIO=y
CONFIG_TOUCHSCREEN_MELFAS_MIP4=y
CONFIG_INPUT_REGULATOR_HAPTIC=y

# Board GPIO-controlled rails and S2MPU05 PMIC regulators
CONFIG_REGULATOR=y
CONFIG_REGULATOR_FIXED_VOLTAGE=y
CONFIG_MFD_SEC_I2C=y
CONFIG_REGULATOR_S2MPS11=y

# S2MU005 fuel gauge
CONFIG_POWER_SUPPLY=y
CONFIG_BATTERY_S2MU005=y
