# Qualcomm MSM8916/APQ8016 LinuxBoot SoC enablement fragment
# Layer this after tinyconfig and any generic LinuxBoot/userland fragment.

# Platform sizing
CONFIG_ARCH_QCOM=y
CONFIG_NR_CPUS=4

# Core Qualcomm firmware/resource plumbing
CONFIG_PM=y
CONFIG_QCOM_SCM=y
CONFIG_QCOM_SMEM=y
CONFIG_QCOM_SOCINFO=y
CONFIG_HWSPINLOCK=y
CONFIG_HWSPINLOCK_QCOM=y
CONFIG_MAILBOX=y
CONFIG_QCOM_APCS_IPC=y
CONFIG_RPMSG_QCOM_SMD=y
CONFIG_QCOM_SMD_RPM=y
CONFIG_QCOM_CLK_SMD_RPM=y
CONFIG_QCOM_RPMPD=y

# Clocks, resets, pinctrl, GPIO and PMIC access
CONFIG_COMMON_CLK_QCOM=y
CONFIG_MSM_GCC_8916=y
CONFIG_PINCTRL_MSM=y
CONFIG_PINCTRL_MSM8916=y
CONFIG_GPIO_SHARED_PROXY=y
CONFIG_SPMI=y
CONFIG_SPMI_MSM_PMIC_ARB=y
CONFIG_MFD_SPMI_PMIC=y
CONFIG_PINCTRL_QCOM_SPMI_PMIC=y
CONFIG_REGULATOR=y
CONFIG_REGULATOR_QCOM_SMD_RPM=y
CONFIG_POWER_RESET_MSM=y
CONFIG_POWER_RESET_QCOM_PON=y
CONFIG_PM_DEVFREQ=y

# BLSP UART/I2C/SPI buses
CONFIG_TTY=y
CONFIG_SERIAL_MSM=y
CONFIG_SERIAL_MSM_CONSOLE=y
CONFIG_I2C=y
CONFIG_I2C_QUP=y
CONFIG_SPI=y
CONFIG_SPI_QUP=y
CONFIG_DMADEVICES=y
CONFIG_QCOM_BAM_DMA=y

# eMMC/SD storage
CONFIG_BLOCK=y
CONFIG_MMC=y
CONFIG_MMC_BLOCK=y
CONFIG_MMC_SDHCI=y
CONFIG_MMC_SDHCI_PLTFM=y
CONFIG_MMC_SDHCI_MSM=y

# USB HS controller/PHY. Gadget functions belong in userland config.
CONFIG_USB_SUPPORT=y
CONFIG_USB=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_GADGET=y
CONFIG_USB_CHIPIDEA=y
CONFIG_USB_CHIPIDEA_UDC=y
CONFIG_USB_CHIPIDEA_HOST=y
CONFIG_USB_CHIPIDEA_MSM=y
CONFIG_GENERIC_PHY=y
CONFIG_PHY_QCOM_USB_HS=y
