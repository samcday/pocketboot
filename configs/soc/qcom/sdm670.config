# Qualcomm SDM670 LinuxBoot SoC enablement fragment
# Layer this after tinyconfig and any generic LinuxBoot/userland fragment.

# Platform sizing
CONFIG_ARCH_QCOM=y
CONFIG_NR_CPUS=8

# Core Qualcomm firmware/resource plumbing
CONFIG_PM=y
CONFIG_QCOM_SCM=y
CONFIG_QCOM_COMMAND_DB=y
CONFIG_QCOM_RPMH=y
CONFIG_QCOM_RPMHPD=y
CONFIG_QCOM_CLK_RPMH=y
CONFIG_QCOM_SMEM=y
CONFIG_QCOM_SOCINFO=y
CONFIG_HWSPINLOCK=y
CONFIG_HWSPINLOCK_QCOM=y

# Clocks, resets, pinctrl, GPIO and interrupts
CONFIG_COMMON_CLK_QCOM=y
CONFIG_SDM_GCC_845=y
CONFIG_PINCTRL_MSM=y
CONFIG_PINCTRL_SDM670=y
CONFIG_PINCTRL_QCOM_SPMI_PMIC=y
CONFIG_QCOM_PDC=y

# PMIC/regulator access
CONFIG_SPMI=y
CONFIG_SPMI_MSM_PMIC_ARB=y
CONFIG_MFD_SPMI_PMIC=y
CONFIG_REGULATOR=y
CONFIG_REGULATOR_FIXED_VOLTAGE=y
CONFIG_REGULATOR_QCOM_RPMH=y
CONFIG_POWER_RESET_QCOM_PON=y

# Interconnects and IOMMU required by on-SoC bus/storage devices
CONFIG_INTERCONNECT=y
CONFIG_INTERCONNECT_QCOM=y
CONFIG_INTERCONNECT_QCOM_SDM670=y
CONFIG_IOMMU_SUPPORT=y
CONFIG_ARM_SMMU=y

# GENI UART/I2C buses used by sargo console and board peripherals
CONFIG_TTY=y
CONFIG_SERIAL_QCOM_GENI=y
CONFIG_SERIAL_QCOM_GENI_CONSOLE=y
CONFIG_I2C=y
CONFIG_QCOM_GENI_SE=y
CONFIG_I2C_QCOM_GENI=y
CONFIG_DMADEVICES=y
CONFIG_QCOM_GPI_DMA=y

# eMMC storage
CONFIG_BLOCK=y
CONFIG_MMC=y
CONFIG_MMC_BLOCK=y
CONFIG_MMC_SDHCI=y
CONFIG_MMC_SDHCI_PLTFM=y
CONFIG_MMC_SDHCI_MSM=y

# USB peripheral controller and HS PHY. Gadget functions belong in userland config.
CONFIG_NVMEM=y
CONFIG_NVMEM_QCOM_QFPROM=y
CONFIG_GENERIC_PHY=y
CONFIG_PHY_QCOM_QUSB2=y
CONFIG_USB_SUPPORT=y
CONFIG_USB_GADGET=y
CONFIG_USB_DWC3=y
CONFIG_USB_DWC3_GADGET=y
CONFIG_USB_DWC3_QCOM=y
