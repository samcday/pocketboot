# Qualcomm SDM845 LinuxBoot SoC enablement fragment
# Layer this after tinyconfig and any generic LinuxBoot/userland fragment.

# Platform sizing
CONFIG_ARCH_QCOM=y
CONFIG_NR_CPUS=8

# Core Qualcomm firmware/resource plumbing
CONFIG_PM=y
CONFIG_QCOM_SCM=y
CONFIG_QCOM_COMMAND_DB=y
CONFIG_QCOM_RPMH=y
CONFIG_QCOM_CLK_RPMH=y
CONFIG_QCOM_RPMHPD=y
CONFIG_QCOM_SMEM=y
CONFIG_QCOM_SOCINFO=y
CONFIG_HWSPINLOCK=y
CONFIG_HWSPINLOCK_QCOM=y
CONFIG_CPU_IDLE=y
CONFIG_ARM_PSCI_CPUIDLE=y
CONFIG_ARM_PSCI_CPUIDLE_DOMAIN=y
CONFIG_MAILBOX=y
CONFIG_QCOM_APCS_IPC=y
CONFIG_QCOM_PDC=y
CONFIG_QCOM_GENI_SE=y
CONFIG_INTERCONNECT=y
CONFIG_INTERCONNECT_QCOM=y
CONFIG_INTERCONNECT_QCOM_SDM845=y
CONFIG_INTERCONNECT_QCOM_OSM_L3=y

# Clocks, resets, pinctrl, GPIO, PMIC access and nvmem calibration
CONFIG_COMMON_CLK_QCOM=y
CONFIG_SDM_GCC_845=y
CONFIG_PINCTRL_MSM=y
CONFIG_PINCTRL_SDM845=y
CONFIG_SPMI=y
CONFIG_SPMI_MSM_PMIC_ARB=y
CONFIG_MFD_SPMI_PMIC=y
CONFIG_PINCTRL_QCOM_SPMI_PMIC=y
CONFIG_REGULATOR=y
CONFIG_REGULATOR_QCOM_RPMH=y
CONFIG_POWER_RESET_MSM=y
CONFIG_POWER_RESET_QCOM_PON=y
CONFIG_NVMEM=y
CONFIG_NVMEM_QCOM_QFPROM=y

# IOMMU for UFS, USB and GENI DMA clients
CONFIG_IOMMU_SUPPORT=y
CONFIG_ARM_SMMU=y
CONFIG_ARM_SMMU_QCOM=y

# GENI UART/I2C/SPI buses
CONFIG_TTY=y
CONFIG_SERIAL_QCOM_GENI=y
CONFIG_SERIAL_QCOM_GENI_CONSOLE=y
CONFIG_I2C=y
CONFIG_I2C_QCOM_GENI=y
CONFIG_SPI=y
CONFIG_SPI_QCOM_GENI=y
CONFIG_DMADEVICES=y
CONFIG_QCOM_GPI_DMA=y

# UFS storage
CONFIG_BLOCK=y
CONFIG_SCSI=y
CONFIG_BLK_DEV_SD=y
CONFIG_SCSI_UFSHCD=y
CONFIG_SCSI_UFSHCD_PLATFORM=y
CONFIG_SCSI_UFS_QCOM=y
CONFIG_GENERIC_PHY=y
CONFIG_PHY_QCOM_QMP=y
# CONFIG_PHY_QCOM_QMP_COMBO is not set
CONFIG_PHY_QCOM_QMP_UFS=y
# CONFIG_PHY_QCOM_QMP_USB is not set
# CONFIG_PHY_QCOM_QMP_USB_LEGACY is not set

# USB HS PHY and DWC3 gadget controller
CONFIG_USB_SUPPORT=y
CONFIG_USB=y
CONFIG_USB_GADGET=y
CONFIG_USB_DWC3=y
CONFIG_USB_DWC3_GADGET=y
CONFIG_USB_DWC3_QCOM=y
CONFIG_PHY_QCOM_QUSB2=y
