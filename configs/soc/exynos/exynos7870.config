# Samsung Exynos 7870 LinuxBoot SoC enablement fragment
# Layer this after tinyconfig and any generic LinuxBoot/userland fragment.

# Platform sizing
CONFIG_ARCH_EXYNOS=y
CONFIG_NR_CPUS=8

# Core Samsung clocks, pinctrl, GPIO, PMU and reboot plumbing
CONFIG_PM=y
CONFIG_COMMON_CLK_SAMSUNG=y
CONFIG_EXYNOS_ARM64_COMMON_CLK=y
CONFIG_PINCTRL_EXYNOS=y
CONFIG_SOC_SAMSUNG=y
CONFIG_EXYNOS_CHIPID=y
CONFIG_EXYNOS_PMU=y
CONFIG_CLKSRC_EXYNOS_MCT=y
CONFIG_MFD_SYSCON=y
CONFIG_POWER_RESET_SYSCON=y
CONFIG_SYSCON_REBOOT_MODE=y

# UART and I2C buses
CONFIG_TTY=y
CONFIG_SERIAL_SAMSUNG=y
CONFIG_SERIAL_SAMSUNG_CONSOLE=y
CONFIG_I2C=y
CONFIG_I2C_EXYNOS5=y
CONFIG_I2C_S3C2410=y

# eMMC/SD storage
CONFIG_BLOCK=y
CONFIG_MMC=y
CONFIG_MMC_BLOCK=y
CONFIG_MMC_DW=y
CONFIG_MMC_DW_PLTFM=y
CONFIG_MMC_DW_EXYNOS=y

# USB DRD controller/PHY. Gadget functions belong in userland config.
CONFIG_GENERIC_PHY=y
CONFIG_PHY_EXYNOS5_USBDRD=y
CONFIG_USB_SUPPORT=y
CONFIG_USB=y
CONFIG_USB_GADGET=y
CONFIG_USB_DWC3=y
CONFIG_USB_DWC3_GADGET=y
CONFIG_USB_DWC3_EXYNOS=y
